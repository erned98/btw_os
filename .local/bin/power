#!/bin/sh

notify-send 'Hello user!' 'Remember to take regular breaks and drink water!'
powerprofilesctl set balanced

while upower -i "$(upower -e | grep 'BAT')" | grep -q "state:.*discharging"
do
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)

    if [ "$capacity" -lt 10 ]; then
        notify-send 'Your battery is critically low and discharging.' \
        'Your computer will shut down. Save your unsaved work.'
        sleep 60
        shutdown -h now
    elif [ "$capacity" -le 30 ]; then
        powerprofilesctl set power-saver
	else
		powerprofilesctl set balanced
    fi

    sleep 30
done
